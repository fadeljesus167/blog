<h1>Login</h1>

<%= form_with url: new_session_path do |form| %>
  <div>
    <%= form.text_field :username, placeholder: 'Username' %>
  </div>

  <div>
    <%= form.password_field :password, placeholder: 'Password' %>
  </div>

  <div>
    <%= form.submit 'Login' %>
  </div>
<% end %>

<h1><%= t('.new_user') %></h1>
<%= link_to t('.create_account'), new_user_path %>